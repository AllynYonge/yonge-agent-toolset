{
  "backend": "codex",
  "skill": "ux-architect",
  "timeout": 240,
  "conversation_mode": "native_session",
  "inherit_runtime_config": true,
  "judge_backend": "hermes",
  "cases": [
    {
      "id": "native-multiturn-ux-dashboard-revision",
      "turns": [
        "用 ux-architect 的方式，为 B2B 客户成功管理 SaaS 的账户健康度页给一个精简 2K 宽视口方案。限制 220 字以内，但必须包含 ASCII 布局、max-width: 1440px、以及一个 [P1]-[P10] 原则标记。",
        "在刚才方案基础上改成三栏宽屏型：左侧账户列表，中间健康度详情，右侧行动建议。限制 220 字以内，不要重复原始需求，直接给修订 ASCII 和一句取舍。"
      ],
      "assertions": [
        {
          "type": "exit_code",
          "value": 0
        },
        {
          "type": "regex",
          "target": "stdout",
          "pattern": "---TURN 1 STDOUT---[\\s\\S]*ASCII|---TURN 1 STDOUT---[\\s\\S]*┌"
        },
        {
          "type": "regex",
          "target": "stdout",
          "pattern": "---TURN 1 STDOUT---[\\s\\S]*(2K|1440|max-width|宽视口)"
        },
        {
          "type": "regex",
          "target": "stdout",
          "pattern": "---TURN 1 STDOUT---[\\s\\S]*\\[P[1-9]0?\\]"
        },
        {
          "type": "regex",
          "target": "stdout",
          "pattern": "---TURN 2 STDOUT---[\\s\\S]*(三栏|左侧|中间|右侧|Left|Center|Right|fixed|fluid|240px|320px|账户列表[\\s\\S]*健康度详情[\\s\\S]*行动建议|Accounts[\\s\\S]*Health Detail[\\s\\S]*Actions)"
        },
        {
          "type": "regex",
          "target": "stdout",
          "pattern": "---TURN 2 STDOUT---[\\s\\S]*(账户列表|健康度详情|行动建议|Accounts|Health Detail|Actions)"
        },
        {
          "type": "regex",
          "target": "stdout",
          "pattern": "---TURN 2 STDOUT---[\\s\\S]*(┌|ASCII|max-width|1440)"
        }
      ]
    }
  ]
}
